    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "latest",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=20"
  }
